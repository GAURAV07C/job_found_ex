# ===== Server =====
PORT=3000
# Shared secret between the extension and this backend (set the same in extension profile)
API_KEY=job-founder-hunter-dev-key

# ===== Redis (required by BullMQ queue) =====
REDIS_URL=redis://localhost:6379

# ===== SMTP (used by Nodemailer to send real emails) =====
# Gmail example: host smtp.gmail.com, port 465, secure true, user = your gmail, pass = 16-char App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# The "From" address shown to recipients. Must be the same as (or a send-as alias of) SMTP_USER.
MAIL_FROM=Gaurav Kumar <your-email@gmail.com>

# Public URL used inside tracking links/pixels (must be reachable by recipients)
# e.g. https://mail.yourdomain.com  — localhost only works for local testing.
PUBLIC_BASE_URL=http://localhost:3000

# Rate limiting for the queue (emails per window)
# e.g. 1 email every 5 seconds => MAX_PER_WINDOW=1, WINDOW_MS=5000
QUEUE_MAX_PER_WINDOW=1
QUEUE_WINDOW_MS=5000

# Max emails processed at the same time
QUEUE_CONCURRENCY=1

# How long (ms) to keep retrying a failed send before marking it failed
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=10000
